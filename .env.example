PORT=8788

# Optional for production/shared use.
# If set, API requests must include Authorization: Bearer <ACCESS_TOKEN>.
ACCESS_TOKEN=

# Simple dashboard accounts. Change these in Railway Variables.
COMMISSIONER_USERNAME=commissioner
COMMISSIONER_PASSWORD=dais
COMMISSIONER_NAME=Commissioner
AIDE1_USERNAME=aide1
AIDE1_PASSWORD=aide
AIDE1_NAME=Aide 1
AIDE2_USERNAME=aide2
AIDE2_PASSWORD=aide
AIDE2_NAME=Aide 2

# Required only when wiring live transcription / model calls.
OPENAI_API_KEY=
OPENAI_ANSWER_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe
TRANSCRIPT_CHUNK_SECONDS=18

# Optional official or public meeting source URL to attach to a live room.
CMB_DEFAULT_LIVE_URL=https://www.youtube.com/@cityofmiamibeach/live
